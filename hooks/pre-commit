#!/usr/bin/env bash
# =============================================================================
# pre-commit hook — refuse commits whose staged content names an
# AI assistant or attribution-to-an-assistant phrasing.
#
# This repo is an operator-facing tool and we want commit history and
# tracked files to read like a single human author wrote them. Mentions
# of an AI assistant in code, docs, or commit message bodies leak
# operational detail that doesn't belong in the work product.
#
# Install (per-clone, opt-in):
#   ln -s ../../hooks/pre-commit  .git/hooks/pre-commit
#   ln -s ../../hooks/commit-msg  .git/hooks/commit-msg
#
# Override (rare, e.g. you really mean to write the word):
#   git commit --no-verify
# =============================================================================

set -euo pipefail

# Patterns to refuse. Case-insensitive. Word-bounded for "AI" so e.g.
# "main" / "wait" / "tail" / "fail" don't trip the check.
patterns=(
  '\bclaude\b'
  '\banthropic\b'
  '\bco-authored.by\b'
  '\bagent\b'
  '\bAI\b'
  '\bassistant\b'
  '\bLLM\b'
)

# Collect staged additions (lines added; ignore deletions and context).
# The hooks/ directory is exempt because it contains the patterns it
# checks for — installing the hook and then committing it would
# self-reject otherwise. hooks/README.md lists the patterns by design.
diff="$(git diff --cached --diff-filter=ACMRT -- '.' ':(exclude)hooks/')"

if [[ -z "$diff" ]]; then
  exit 0
fi

# Build one alternation regex; cheaper than looping each pattern.
re="$(IFS='|'; printf '%s' "${patterns[*]}")"

# `+` lines are insertions, but skip the diff-header `+++` which always
# starts with three pluses — easily filtered by checking the second char.
hits="$(printf '%s\n' "$diff" \
  | grep -E '^\+[^+]' \
  | grep -inE "$re" \
  || true)"

if [[ -n "$hits" ]]; then
  cat >&2 <<EOF

pre-commit: refusing to add AI-assistant references to tracked content.

  Hits in staged diff:
$(printf '%s\n' "$hits" | sed 's/^/    /')

  Patterns checked: ${patterns[*]}

  Rewrite to neutral phrasing, then re-stage and re-commit. If you
  truly intended this content (rare), bypass with: git commit --no-verify
EOF
  exit 1
fi

exit 0
