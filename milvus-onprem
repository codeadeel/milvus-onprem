#!/usr/bin/env bash
# =============================================================================
# milvus-onprem — single-binary CLI dispatcher
#
# Routes subcommands (init, render, up, down, status, wait, teardown,
# bootstrap, ...) to lib/cmd_<name>.sh. Each cmd_* function handles its
# own argument parsing.
# =============================================================================

set -euo pipefail

# Resolve the repo root from this script's location, even via symlinks.
REPO_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export REPO_ROOT

# Source order matters — log first, then env (uses log), then role (uses env), etc.
source "$REPO_ROOT/lib/log.sh"
source "$REPO_ROOT/lib/env.sh"
source "$REPO_ROOT/lib/role.sh"
source "$REPO_ROOT/lib/render.sh"
source "$REPO_ROOT/lib/dc.sh"
source "$REPO_ROOT/lib/etcd.sh"
source "$REPO_ROOT/lib/minio.sh"
source "$REPO_ROOT/lib/host.sh"
source "$REPO_ROOT/lib/backup.sh"
source "$REPO_ROOT/lib/watchdog.sh"

# Source every cmd_*.sh — each contributes a single command.
for f in "$REPO_ROOT"/lib/cmd_*.sh; do
  [[ -f "$f" ]] && source "$f"
done

# install_watchdog uses cmd_install.sh's WATCHDOG_UNIT_NAME / SYSTEMD_UNIT_DIR
# and _install_sudo_if_needed, so source it after the cmd_*.sh sweep.
source "$REPO_ROOT/lib/install_watchdog.sh"

usage() {
  cat <<EOF
Usage: milvus-onprem <command> [options]

  init             Initialise this node. Run on the first VM (--mode=distributed)
                   or single-VM deploys (--mode=standalone). Required first step.
  join             Join a running cluster. Run on every other VM with the
                   token printed by the bootstrap node's init.
  preflight        Pre-deploy sanity check (docker / disk / ports / inter-peer TCP).
                   Auto-runs at the top of init/join.

  bootstrap        Render + up + wait + create bucket. Idempotent.
  render           Re-render templates after editing cluster.env.
  up               Start all containers on this node.
  down             Stop all containers (data preserved).
  status           Local + cluster health.
  wait             Block until cluster converges.
  teardown         Stop + wipe. --full also removes cluster.env.

  remove-node      Gracefully remove a peer (distributed mode only).
  rotate-token     Rotate CLUSTER_TOKEN atomically across every peer.
  migrate-pulsar   Move the 2.5 Pulsar singleton to a different peer
                   (prerequisite for removing the current PULSAR_HOST).

  backup-etcd      Snapshot etcd to a .db file.
  create-backup    milvus-backup snapshot of live data (stored in MinIO).
  export-backup    Copy a backup from MinIO to a filesystem dir.
  restore-backup   Import a milvus-backup snapshot.

  upgrade          Rolling Milvus image-tag upgrade (same major.minor).
  jobs             Manage daemon jobs: list / show / cancel / types.

  smoke            End-to-end smoke test against the LB.
  version          CLI + image tag versions.
  urls             Connection URLs to share with clients.
  ps               docker ps filtered to milvus-*.
  logs             Tail logs for a component.

  install          Drop the CLI on PATH + bash completion (system-wide).
  uninstall        Reverse of install (data untouched — see teardown).
  watchdog         Standalone peer-down poller (legacy; daemon includes one).
  maintenance      Operator hygiene: prune-images / prune-logs / prune-etcd-jobs.

  help             Show this message.

For per-command help: milvus-onprem <command> --help

Repo: https://github.com/codeadeel/milvus-onprem
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)            cmd_init            "$@" ;;
    render)          cmd_render          "$@" ;;
    up)              cmd_up              "$@" ;;
    down)            cmd_down            "$@" ;;
    bootstrap)       cmd_bootstrap       "$@" ;;
    status)          cmd_status          "$@" ;;
    wait)            cmd_wait            "$@" ;;
    teardown)        cmd_teardown        "$@" ;;
    join)            cmd_join            "$@" ;;
    backup-etcd)     cmd_backup_etcd     "$@" ;;
    create-backup)   cmd_create_backup   "$@" ;;
    export-backup)   cmd_export_backup   "$@" ;;
    restore-backup)  cmd_restore_backup  "$@" ;;
    jobs)            cmd_jobs            "$@" ;;
    remove-node)     cmd_remove_node     "$@" ;;
    upgrade)         cmd_upgrade         "$@" ;;
    smoke)           cmd_smoke           "$@" ;;
    version)         cmd_version         "$@" ;;
    urls)            cmd_urls            "$@" ;;
    ps)              cmd_ps              "$@" ;;
    logs)            cmd_logs            "$@" ;;
    install)         cmd_install         "$@" ;;
    uninstall)       cmd_uninstall       "$@" ;;
    watchdog)        cmd_watchdog        "$@" ;;
    maintenance)     cmd_maintenance     "$@" ;;
    rotate-token)    cmd_rotate_token    "$@" ;;
    migrate-pulsar)  cmd_migrate_pulsar  "$@" ;;
    preflight)       cmd_preflight       "$@" ;;
    -h|--help|help)  usage ;;
    *)               err "unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
